	<script>
		$(document).ready(function () {
			var dropdown = $("#territories").data("kendoDropDownList");
			var data = [
				{ TerritoryID: 1, TerritoryDescription: "North Region" },
				{ TerritoryID: 2, TerritoryDescription: "South Region" },
				{ TerritoryID: 3, TerritoryDescription: "East Region" },
				{ TerritoryID: 4, TerritoryDescription: "West Region" }
			];

			// Set the hardcoded data directly to the DataSource of the DropDownList
			dropdown.setDataSource(data);
		});
	</script>
