	<link href="~/css/kendo.material-main.min.css" rel="stylesheet" type="text/css" />
	<style>
		.text-danger-popup {
			margin-left: 200px;
			color: red;
			font-size: medium;
			margin-top: -5px;
		}

		.viewmodeclose {
			background-color: #18407C;
			color: white;
			border: none;
			cursor: pointer;
			font-size: 14px;
			padding: 5px 10px;
			border-radius: 5px;
		}

		.reuqest {
			margin-bottom: 15px;
		}

		.new-head {
			padding: 5px 15px;
			width: auto;
			color: white;
			background-color: #18407C;
			border-radius: 5px;
			border-radius: 5px;
			margin-bottom: 15px;
		}

		.fields-box {
			border: 2px solid black;
		}


		.k-filterable .k-header {
			text-align: left !important;
			margin-left: -10px;
			background-color: #c6ecc6;
		}

		.k-grid-toolbar {
			display: flex;
			justify-content: flex-start; /* Align toolbar buttons (like search) to the left */
		}

		.k-grid-pager {
			background-color: #c6ecc6;
		}

		/* Adjust the filter input box */
		.k-filtercell .k-filterinput {
			text-align: left !important; /* Align filter input to the left */
			background-color: #c6ecc6;
		}

		/* Align the filter dropdowns */
		.k-filtercell .k-dropdown {
			text-align: left !important; /* Align filter dropdown to the left */
			background-color: #c6ecc6;
		}

		/* Optional: Adjust the filter button position */
		.k-grid-toolbar .k-button {
			margin-right: 10px; /* Give some space between buttons if necessary */
			background-color: #c6ecc6;
		}



		/* Optional: Add some padding if necessary */
		.k-grid .k-filter-cell .k-filter-menu .k-textbox {
			padding-right: 5px; /* Add padding to prevent any unwanted border */
		}

		.k-grid-toolbar .k-button {
			background-color: #18407C; /* Your desired background color */
			color: white; /* Your desired text color */
			border: none; /* Optional: Remove border */
		}

			/* Change hover effect */
			.k-grid-toolbar .k-button:hover {
				background-color: #8dc63f; /* Hover background color */
				color: white; /* Text color on hover */
			}
		/* Apply background color for even rows */

		.k-grid tr:nth-child(even) {
			/* background-color: green; */
			color: black;
		}

		.k-button-md {
			padding: 2px 8px;
		}
		/* Apply background color for odd rows */
		.k-grid tr:nth-child(odd) {
			background-color: #f0f2f5;
		}

		#first {
			padding: 8px;
		}

		.k-grid tbody td {
			padding: 8px;
			line-height: 16px;
		}


		.k-grid tr td {
			border: 1px solid darkgrey;
			background-color: #ecf9ec;
		}

		.k-grid table tr:hover td {
			background: #18407C !important;
			cursor: pointer !important;
			color: white;
		}

	</style>
	</style>
