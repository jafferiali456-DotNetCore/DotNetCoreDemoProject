	<style>

		.k-grid td,
		.k-grid th {
			border-right: 1px solid #ccc !important; /* vertical line between columns */
		}

		.text-danger-msg {
			display: block;
			min-height: 18px; /* Reserve space even when no error */
			font-size: 13px;
			color: red;
			margin-bottom: -10px;
			margin-top: 4px;
		}


		.error-overlay {
			display: none;
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100%;
			background: rgba(0, 0, 0, 0.4);
			z-index: 9998;
		}

		/* Dialog container */
		.error-dialog {
			display: none;
			position: fixed;
			top: 30%;
			left: 50%;
			transform: translate(-50%, -30%);
			background: #fff;
			border: 1px solid #ccc;
			border-radius: 10px;
			padding: 20px;
			width: 400px;
			max-width: 90%;
			box-shadow: 0px 4px 12px rgba(0, 0, 0, 0.2);
			z-index: 9999;
			font-family: "Segoe UI", sans-serif;
			animation: fadeIn 0.3s ease-in-out;
		}

		/* Title */
		.error-dialog-title {
			margin-top: 0;
			color: #c0392b;
			font-size: 18px;
			font-weight: 600;
		}

		/* Message */
		.error-dialog-message {
			margin-top: 15px;
			padding: 15px 0;
			color: #2c3e50;
			font-weight: 400;
			font-size: 15px;
			line-height: 1.4;
		}

		/* Button */
		.error-dialog-btn {
			background: #18407C;
			color: white;
			border: none;
			border-radius: 6px;
			padding: 8px 16px;
			cursor: pointer;
			font-size: 14px;
			transition: background 0.2s;
		}

			.error-dialog-btn:hover {
				background: #a93226;
			}

		/* Smooth fade animation */
		@@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translate(-50%, -40%);
			}

			to {
				opacity: 1;
				transform: translate(-50%, -30%);
			}
		}


		.custom-dialog {
			display: none;
			position: fixed;
			top: 30%;
			left: 50%;
			transform: translate(-50%, -50%);
			background: #fff;
			border-radius: 10px;
			padding: 20px;
			width: 420px;
			box-shadow: 0px 4px 20px rgba(0,0,0,0.25);
			z-index: 9999;
			text-align: center;
			font-family: Arial, sans-serif;
		}

		.dialog-title {
			display: flex;
			margin-left: 10px;
			font-size: 20px;
			font-weight: 600;
		}

		.dialog-message {
			margin: 15px 0;
			color: #333;
			font-size: 15px;
		}

		.dialog-codebox {
			margin-top: 15px;
			padding: 10px;
			background: #f7f7f7;
			border: 1px dashed #aaa;
			border-radius: 5px;
			display: flex;
			justify-content: space-between;
			align-items: center;
			font-family: monospace;
		}

		.copy-btn {
			background: #007bff;
			color: #fff;
			border: none;
			padding: 5px 10px;
			border-radius: 4px;
			cursor: pointer;
		}

			.copy-btn:hover {
				background: #0056b3;
			}

		.dialog-btn {
			margin-top: 15px;
			padding: 6px 12px;
			border: none;
			background: #18407C;
			color: #fff;
			border-radius: 4px;
			cursor: pointer;
		}

			.dialog-btn:hover {
				background: #222;
			}

	</style>
	<style>

		.k-grid td {
			overflow: hidden; /* grid ka layout safe rahe */
			position: relative;
		}

		.tooltip-wrapper {
			position: relative;
			display: inline-block;
			width: 100%;
			height: 100%;
		}

			.tooltip-wrapper .tooltip-text {
				visibility: hidden;
				position: fixed;
				width: 100px;
				background-color: #333;
				color: #fff;
				text-align: center;
				border-radius: 4px;
				padding: 4px 6px;
				position: absolute;
				z-index: 9999 !important;
				bottom: 125%;
				left: 50%;
				transform: translateX(-50%);
				opacity: 0;
				transition: opacity 0.2s;
				font-size: 12px;
				white-space: nowrap;
			}

			.tooltip-wrapper:hover .tooltip-text {
				visibility: visible;
				opacity: 1;
			}



		/* Ensure all rows have the same styling */
		.k-grid tr {
			position: relative;
		}

		.k-grid .k-edit-cell input[type="text"] {
			width: 100% !important;
			min-width: 200px;
			box-sizing: border-box;
		}
	</style>

	<style>

		#gridAdHocLocations td .k-input,
		#gridAdHocLocations td input,
		#gridAdHocLocations td select,
		#gridAdHocLocations td .k-dropdown {
			width: 100% !important;
			box-sizing: border-box;
		}

		#gridAdHocLocations .k-edit-cell {
			padding: 0 !important;
		}

		.k-window {
			width: 500px !important;
		}

		.k-edit-form-container {
			width: 850px;
		}
	</style>









	<style>




		.validation-list {
			list-style: none;
			padding-left: 0;
		}

		.validation-item {
			margin-bottom: 12px;
			display: flex;
			align-items: center;
			gap: 12px;
		}

		.validation-icon {
			width: 24px;
			height: 24px;
			object-fit: contain;
			display: block;
		}

		.disabled-style {
			background-color: #C6D9EC; /* Grey background */
			color: black; /* Grey text */
			cursor: not-allowed; /* Cursor shows disabled */
		}

		.validation-header {
			position: relative;
			background: linear-gradient(90deg, #18407C, #1f5bb4);
			color: white;
			padding: 15px 20px;
			display: flex;
			justify-content: space-between;
			align-items: center;
			transition: background 0.4s ease;
		}

		.validation-body {
			padding: 20px;
			background-color: #C6D9EC;
			color: #333;
			display: flex;
			justify-content: space-around;
			font-size: 16px;
		}

		.status-indicator {
			font-weight: bold;
			display: flex;
			align-items: center;
			gap: 8px;
			font-size: 16px;
		}

			.status-indicator img {
				width: 22px;
				height: 22px;
			}

		/* ✅ Green header */
		.validation-header.success {
			background: linear-gradient(90deg, #2e7d32, #4caf50);
		}

		/* ❌ Red header */
		.validation-header.failed {
			background: linear-gradient(90deg, #b71c1c, #e53935);
		}


		.text-danger-3 {
			margin-left: 230px;
			display: block;
			color: #dc3545 !important;
			margin-top: -15px;
			min-height: 20px;
			margin-bottom: -11px;
		}



		.display-column {
			display: flex;
			flex-direction: column;
		}

		.viewmodeclose {
			background-color: #18407C;
			color: white;
			border: none;
			cursor: pointer;
			font-size: 14px;
			padding: 5px 10px;
			border-radius: 5px;
		}

		.reuqest {
			margin-bottom: 15px;
		}

		.new-head {
			padding: 5px 15px;
			width: auto;
			color: white;
			background-color: #18407C;
			border-radius: 5px;
			border-radius: 5px;
			margin-bottom: 15px;
		}

			.new-head:hover {
				background-color: green;
				color: white;
			}


		.fields-box {
			border: 2px solid black;
		}


		.k-filterable .k-header {
			text-align: left !important;
			margin-left: -10px;
			background-color: #c6ecc6;
		}

		.k-grid-toolbar {
			display: flex;
			justify-content: flex-start; /* Align toolbar buttons (like search) to the left */
		}

		.k-grid-pager {
			background-color: #c6ecc6;
		}

		/* Adjust the filter input box */
		.k-filtercell .k-filterinput {
			text-align: left !important; /* Align filter input to the left */
			background-color: #c6ecc6;
		}

		/* Align the filter dropdowns */
		.k-filtercell .k-dropdown {
			text-align: left !important; /* Align filter dropdown to the left */
			background-color: #c6ecc6;
		}

		/* Optional: Adjust the filter button position */
		.k-grid-toolbar .k-button {
			margin-right: 10px; /* Give some space between buttons if necessary */
			background-color: #c6ecc6;
		}



		/* Optional: Add some padding if necessary */
		.k-grid .k-filter-cell .k-filter-menu .k-textbox {
			padding-right: 5px; /* Add padding to prevent any unwanted border */
		}

		.k-grid-toolbar .k-button {
			background-color: #18407C; /* Your desired background color */
			color: white; /* Your desired text color */
			border: none; /* Optional: Remove border */
		}

			/* Change hover effect */
			.k-grid-toolbar .k-button:hover {
				background-color: #8dc63f; /* Hover background color */
				color: white; /* Text color on hover */
			}
		/* Apply background color for even rows */

		.k-grid tr:nth-child(even) {
			/* background-color: green; */
			color: black;
		}

		.k-button-md {
			padding: 2px 8px;
		}
		/* Apply background color for odd rows */
		.k-grid tr:nth-child(odd) {
			background-color: #f0f2f5;
		}

		#first {
			padding: 8px;
		}

		.k-grid tbody td {
			padding: 8px;
			line-height: 16px;
		}


		.k-grid tr td {
			border: 1px solid darkgrey;
			background-color: #ecf9ec;
		}

		.k-grid table tr:hover td {
			background: #18407C !important;
			cursor: pointer !important;
			color: white;
		}

	</style>
	<style>
		#dynamic-menu {
			padding-left: 10px;
		}

		.k-treeview .k-in {
			font-size: 15px;
			color: #333;
		}

		.k-treeview {
			background-color: transparent;
			border: none;
		}
	</style>
	<style>
		.has-sub > .js-arrow::after {
			content: ' ▼';
			float: right;
			transition: transform 0.2s ease;
		}

		.has-sub.open > .js-arrow::after {
			transform: rotate(-180deg);
		}

		.js-sub-list {
			display: none;
		}
	</style>

