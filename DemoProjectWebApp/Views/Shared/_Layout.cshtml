	<script>

		$(document).ready(function () {
			$.getJSON("/Home/GetMenu", function (data) {
				const menuTree = buildTree(data, null);
				const html = renderMenu(menuTree);
				$('#dynamic-menu').html(html);
			});

			function buildTree(data, parentId) {
				return data.filter(x => x.ParentID === parentId)
					.map(x => ({
						...x,
						children: buildTree(data, x.MenuID)
					}));
			}

			function renderMenu(items) {
				let html = '<ul class="list-unstyled navbar__list">';
				items.forEach(item => {
					if (item.children && item.children.length > 0) {
						html += `
						<li class="has-sub">
							<a class="js-arrow" href="#">${item.Text}</a>
							<ul class="list-unstyled navbar__sub-list js-sub-list">
								${renderMenuItems(item.children)}
							</ul>
						</li>
					`;
					} else {
						html += `
						<li>
								<a class="side-menu" href="${item.Navigate}">${item.Text}</a>

						</li>
					`;
					}
				});
				html += '</ul>';
				return html;
			}
			//<a class="side-menu" href="javascript:void(0);" data-url="${item.Navigate}">${item.Text}</a>


			function renderMenuItems(children) {
				return children.map(child =>
					child.children && child.children.length > 0
						? `
						<li class="has-sub">
							<a class="js-arrow" href="#">${child.Text}</a>
							<ul class="list-unstyled navbar__sub-list js-sub-list">
								${renderMenuItems(child.children)}
							</ul>
						</li>
					`
						: `<li><a class="side-menu" href="${child.Navigate}">${child.Text}</a></li>`
				).join('');
			}
			//<a class="side-menu" href="javascript:void(0);" data-url="${child.Navigate}">${child.Text}</a>
			$(document).on('click', '.side-menu', function (e) {
				e.preventDefault();
				const url = $(this).data('url');
				if (url && url !== "#") {
					e.preventDefault();
				}
			});
			$(document).on('click', '.js-arrow', function (e) {
				e.preventDefault(); // only for menu toggles
				var $submenu = $(this).next('.js-sub-list');
				$submenu.slideToggle();
				$(this).parent().toggleClass('open');
			});
		});
	</script>

