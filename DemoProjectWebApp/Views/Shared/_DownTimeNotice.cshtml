
@inject DemoProjectWebApp.DAO.ApplicationDataService AppData

@{
    // Only show downtimes whose show time has passed and not ended yet
    var validDowntimes = AppData.DownTimeList?
        .Where(x => x.ShowDateTime <= DateTime.Now && x.EndDate >= DateTime.Now)
        .OrderBy(x => x.StartDate)
        .ToList();
}
@* @if (AppData.DownTimeList != null && AppData.DownTimeList.Any()) *@
@if (validDowntimes != null && validDowntimes.Any())
{
        <div class="alert alert-danger shadow-sm" style="border-left: 6px solid #dc3545; border-radius: 10px;">
            <div class="mb-2">
                <i class="bi bi-exclamation-triangle-fill text-danger fs-4 me-2"></i>
                <h4 class="mb-0 fw-bold" style="color: #dc3545;">⚠ Scheduled Downtime Notice</h4>
            </div>

            <p class="mb-3 text-muted">
                Our system will be temporarily unavailable during the following maintenance period(s):
            </p>

            <div class="table-responsive">
                <table class="table table-bordered table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Reason</th>
                            <th>Start Time</th>
                            <th>End Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in AppData.DownTimeList)
                        {
                                <tr>
                                    <td>@item.Reason</td>
                                    <td>@item.StartDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                    <td>@item.EndDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                </tr>
                        }
                    </tbody>
                </table>
            </div>

            <small class="text-muted d-block mt-2">
                Last updated: @AppData.LastLoadedTime.ToString("dd MMM yyyy, hh:mm tt")
            </small>
        </div>
}
