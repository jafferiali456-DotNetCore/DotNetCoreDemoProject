@using Kendo.Mvc.UI

@model string // Or the type of your foreign key

@(Html.Kendo().DropDownListFor(m => m)
    .OptionLabel("Select Action")
    .DataTextField("Text")
    .DataValueField("Value")
    .BindTo((IEnumerable<SelectListItem>)ViewData["actions"])
     .ValuePrimitive(true)         // sirf Value bind hoga model me
    .Template("#= Text #")        // list me hamesha Text hi show hoga
    .ValueTemplate("#= Text #")
)


