
@model DemoProjectWebApp.Controllers.LoginRequest

@{
    ViewData["Title"] = "Log in";
    Layout = "~/Views/Shared/_CustomLayout.cshtml";
}

<!-- Sing in  Form -->
<section class="sign-in">
    <div class="container">
        <div class="signin-content" style="margin-top:85px;">
            <div class="signin-image">
                <figure><img src="~/images/hosbg-title-01.jpg" alt="sing up image"></figure>
                <div class="HEADING" style="margin-top:-30px ;"> <h2 class="form-title" style="text-align: center; color: #4ea5d2; ">Bhit OrgChart System</h2></div>
            </div>

            <div class="signin-form" style="margin-top:35px;">
                <h2 class="form-title" style="color: #4ea5d2; text-align:center">Sign In</h2>
@*<div class="main">
    <div class="bold-h">
       Sign in
    </div>*@
                <form method="POST" asp-action="Login" asp-controller="LoginModel" class="register-form" id="account">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="form-group">
                        <label asp-for="LoginID"><i class="zmdi zmdi-account material-icons-name"></i></label>
                        <input asp-for="LoginID" aria-required="true" placeholder="Email" type="text"/>
                        <span asp-validation-for="LoginID" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Password"><i class="zmdi zmdi-lock"></i></label>
                        <input asp-for="Password" aria-required="true" placeholder="Password" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    
                    <div class="form-group form-button" style="text-align:center;">
                        <button  type="submit"  style="border-style:none; font-family:Poppins; font-weight:600">Log in</button>
                    </div>
                </form>
                <div class="social-login">
                    <span class="social-label"> Copyright &copy; 2022 - Mazen Pakistan Pvt. Ltd.</span>
                </div>
            </div>
        </div>
    </div>
</section>
@*</div>*@

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}




