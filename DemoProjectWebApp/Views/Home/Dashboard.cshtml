@using System
@{
    Layout = null;
    // Dummy data
    var userName = "Sana Ahmed";
    var userRole = "Creative Director";
    var notifications = new[]{
        new {Title="Attendance Correction Approval", Days="Pending for 2 days"},
        new {Title="Abhi Advance Approval", Days="Pending for 3 days"},
        new {Title="Leave Approval", Days="Pending for 2 days"}
    };

    var quickCards = new[]{
        new {Title="Payroll", Items=new[]{"Pay Statement","Salary Taxation","Comp Statement"}},
        new {Title="Performance & Goals", Items=new[]{"View Goals","Goal Status","Previous Appraisal"}},
        new {Title="Employee Data", Items=new[]{"Update Data","Upload Document","Extract Letter"}},
        new {Title="Leave", Items=new[]{"Submit Leave","View Balance","Modify Leave"}}
    };

    var team = new[]{
        new {Name="Sayed Muhammad Saad", Role="Product Manager"},
        new {Name="Fatima Nayyer", Role="UX Designer"},
        new {Name="Umar Khan", Role="Developer"}
    };

    var news = new[]{
        new {Title="Decibel HRMS launches new module", When="4 days ago"},
        new {Title="Connect '23 - Highlights", When="1 week ago"}
    };

    var todos = notifications;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Decibel - Demo Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f5f7fb;
            font-family: Segoe UI, Roboto, Arial, sans-serif
        }

        .sidebar {
            background: #0d6efd;
            color: white;
            min-height: 100vh;
            padding: 2rem
        }

        .card-ghost {
            background: #ffffff;
            box-shadow: 0 6px 18px rgba(0,0,0,0.06)
        }

        .small-avatar {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            object-fit: cover
        }

        .app-tile {
            min-height: 90px
        }

        .todo-dot {
            width: 10px;
            height: 10px;
            border-radius: 50%;
            background: #ff6b6b;
            display: inline-block;
            margin-right: 8px
        }

        .nav-left {
            width: 240px
        }
        .media (max-width:991px) {
            .nav-left

        {
            display: none
        }

        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar -->
            <aside class="col-12 col-lg-2 nav-left sidebar d-flex flex-column align-items-start">
                <div class="d-flex align-items-center mb-4">
                    <img src="https://i.pravatar.cc/100?img=68" class="small-avatar me-2" alt="avatar">
                    <div>
                        <div style="font-weight:700">@userName</div>
                        <div style="font-size:12px;opacity:0.9">@userRole</div>
                    </div>
                </div>
                <nav class="nav flex-column w-100">
                    <a class="nav-link text-white" href="#">Dashboard</a>
                    <a class="nav-link text-white" href="#">Apps</a>
                    <a class="nav-link text-white" href="#">Settings</a>
                    <a class="nav-link text-white" href="#">Resource Center</a>
                </nav>
            </aside>

            <!-- Main -->
            <main class="col-12 col-lg-10 p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                        <h4 class="mb-0">Good Morning, <strong>@userName</strong></h4>
                        <small class="text-muted">Welcome back to Decibel demo</small>
                    </div>
                    <div class="d-flex align-items-center">
                        <div class="me-3 text-end">
                            <div style="font-weight:700">To Do</div>
                            <small class="text-muted">You have @todos.Length pending items</small>
                        </div>
                        <button class="btn btn-outline-secondary btn-sm">View archive</button>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-xl-8">
                        <div class="card card-ghost p-3 mb-3">
                            <div class="row">
                                @foreach (var card in quickCards)
                                {
                                    <div class="col-6 col-md-3 mb-3">
                                        <div class="p-3 border rounded app-tile">
                                            <div style="font-weight:700">@card.Title</div>
                                            <ul class="mt-2" style="padding-left:18px;font-size:13px">
                                                @foreach (var it in card.Items)
                                                {
                                                    <li>@it</li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                }
                            </div>
                            <hr />
                            <div class="d-flex gap-3">
                                <div class="flex-fill">
                                    <h6 class="mb-1">My Team</h6>
                                    <div class="d-flex gap-2">
                                        @foreach (var t in team)
                                        {
                                            <div class="p-2 text-center" style="min-width:110px">
                                                <img src="https://i.pravatar.cc/64" class="rounded-circle mb-2" style="width:56px;height:56px;object-fit:cover" />
                                                <div style="font-size:13px;font-weight:600">@t.Name</div>
                                                <div style="font-size:12px;color:#666">@t.Role</div>
                                            </div>
                                        }
                                    </div>
                                </div>

                                <div style="width:260px">
                                    <h6 class="mb-1">News & Announcements</h6>
                                    <ul class="list-unstyled small">
                                        @foreach (var n in news)
                                        {
                                            <li class="mb-2">
                                                <div style="font-weight:600">@n.Title</div>
                                                <div class="text-muted" style="font-size:12px">@n.When</div>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-12 col-md-6">
                                <div class="card card-ghost p-3">
                                    <h6>Upcoming Events & Meetings</h6>
                                    <ul class="small mt-2">
                                        <li>Product Revamp Discussion - 02 Aug 2025</li>
                                        <li>Umar Khan's Birthday - 10 Aug 2025</li>
                                    </ul>
                                </div>
                            </div>

                            <div class="col-12 col-md-6">
                                <div class="card card-ghost p-3">
                                    <h6>Wellbeing</h6>
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <div style="font-weight:700">32°C</div>
                                            <div class="text-muted small">You have not taken a break in last 70 days</div>
                                        </div>
                                        <div>
                                            <button class="btn btn-sm btn-primary">Submit Leave</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="col-12 col-xl-4">
                        <div class="card card-ghost p-3 mb-3">
                            <h6>To Do</h6>
                            <ul class="list-unstyled mt-2">
                                @foreach (var td in todos)
                                {
                                    <li class="mb-2 d-flex align-items-start">
                                        <span class="todo-dot mt-1"></span>
                                        <div>
                                            <div style="font-weight:600">@td.Title</div>
                                            <div class="text-muted small">@td.Days</div>
                                        </div>
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="card card-ghost p-3 mb-3">
                            <h6>My Profile</h6>
                            <div class="d-flex align-items-center gap-3">
                                <img src="https://i.pravatar.cc/80?img=68" class="rounded-circle" style="width:64px;height:64px;object-fit:cover" />
                                <div>
                                    <div style="font-weight:700">@userName</div>
                                    <div class="text-muted small">@userRole</div>
                                    <button class="btn btn-sm btn-outline-primary mt-2">View Profile</button>
                                </div>
                            </div>
                        </div>

                        <div class="card card-ghost p-3">
                            <h6>Social</h6>
                            <div class="d-flex gap-2">
                                <div class="text-center p-2 border rounded flex-fill">
                                    <div style="font-weight:700">14,653</div>
                                    <div class="text-muted small">Steps</div>
                                </div>
                                <div class="text-center p-2 border rounded flex-fill">
                                    <div style="font-weight:700">572</div>
                                    <div class="text-muted small">Calories</div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <footer class="mt-4 text-center text-muted small">Decibel HRMS • Demo • 2025</footer>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
